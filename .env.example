# 永豐金 Shioaji API 憑證範本
# 複製為 .env 並填入真實值（.env 不會被 git 追蹤）

# ── 必填：API 金鑰 ──────────────────────────────────────────────
SINOPAC_API_KEY=your_api_key_here
SINOPAC_SECRET_KEY=your_secret_key_here

# ── 交易模式 ────────────────────────────────────────────────────
# true  = 模擬模式（Simulation），不動真錢
# false = 正式模式（Live），下真實委託
SINOPAC_SIMULATION=true

# ── CA 憑證（正式下單必填，模擬可留空）───────────────────────────
# Sinopac 核發的 .pfx 憑證檔案路徑（絕對路徑或相對專案根目錄）
SINOPAC_CA_PATH=
# 憑證密碼
SINOPAC_CA_PASSWD=
# 身分證字號（啟用憑證用）
SINOPAC_PERSON_ID=
